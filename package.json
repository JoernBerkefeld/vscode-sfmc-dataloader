{
    "name": "sfmc-data",
    "displayName": "SFMC Data Loader",
    "description": "Export and import Salesforce Marketing Cloud Engagement Data Extension rows via the mcdata CLI (sfmc-dataloader).",
    "author": "Jörn Berkefeld",
    "license": "MIT",
    "version": "1.1.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/JoernBerkefeld/vscode-sfmc-dataloader.git"
    },
    "bugs": {
        "url": "https://github.com/JoernBerkefeld/vscode-sfmc-dataloader/issues"
    },
    "publisher": "joernberkefeld",
    "categories": [
        "Other"
    ],
    "keywords": [
        "sfmc",
        "salesforce",
        "marketing cloud",
        "data extension",
        "mcdev",
        "mcdata",
        "sfmc-dataloader",
        "csv",
        "tsv",
        "json",
        "exacttarget"
    ],
    "icon": "resources/images/sfmc-dataloader-256.png",
    "galleryBanner": {
        "color": "#032d60",
        "theme": "dark"
    },
    "engines": {
        "vscode": "^1.101.0"
    },
    "main": "./out/extension.js",
    "activationEvents": [
        "onStartupFinished"
    ],
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25",
        "@types/vscode": "^1.101.0",
        "@vscode/vsce": "^3.9.1",
        "esbuild": "^0.28.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^62.0.0",
        "eslint-plugin-prettier": "^5.5.0",
        "eslint-plugin-unicorn": "^64.0.0",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "prettier": "^3.8.1",
        "sfmc-dataloader": "^2.7.0",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.59.1"
    },
    "contributes": {
        "commands": [
            {
                "command": "sfmc-data.initProject",
                "title": "Initialize Project",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.exportDE",
                "title": "Export DE Data",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.exportDEMultiBU",
                "title": "Export DE Data (Multi-BU)",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.importDE",
                "title": "Import DE Data",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.refreshDeCache",
                "title": "Refresh DE Cache",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.importDECrossBU",
                "title": "Import DE Data (Cross-BU)",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.contextExportDE",
                "title": "Export Data",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.contextImportDE",
                "title": "Import Data",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.contextImportToBU",
                "title": "Import to BU...",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.contextExportFromBUs",
                "title": "Export from BUs...",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.showWhatsNew",
                "title": "Show What's New",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.openOutputChannel",
                "title": "Show Output",
                "category": "SFMC Data"
            }
        ],
        "submenus": [
            {
                "id": "sfmc-data.explorerContextMenu",
                "label": "SFMC Data Loader"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "sfmc-data.initProject",
                    "when": "workspaceFolderCount > 0"
                },
                {
                    "command": "sfmc-data.exportDE",
                    "when": "workspaceFolderCount > 0"
                },
                {
                    "command": "sfmc-data.exportDEMultiBU",
                    "when": "workspaceFolderCount > 0"
                },
                {
                    "command": "sfmc-data.importDE",
                    "when": "workspaceFolderCount > 0"
                },
                {
                    "command": "sfmc-data.refreshDeCache",
                    "when": "workspaceFolderCount > 0"
                },
                {
                    "command": "sfmc-data.importDECrossBU",
                    "when": "workspaceFolderCount > 0"
                },
                {
                    "command": "sfmc-data.contextExportDE",
                    "when": "false"
                },
                {
                    "command": "sfmc-data.contextImportDE",
                    "when": "false"
                },
                {
                    "command": "sfmc-data.contextImportToBU",
                    "when": "false"
                },
                {
                    "command": "sfmc-data.contextExportFromBUs",
                    "when": "false"
                },
                {
                    "command": "sfmc-data.openOutputChannel"
                }
            ],
            "explorer/context": [
                {
                    "submenu": "sfmc-data.explorerContextMenu",
                    "when": "resourceFilename =~ /\\.dataExtension-(meta\\.json|doc\\.md)$/ || resourceFilename =~ /\\.mcdata\\./",
                    "group": "sfmc@1"
                }
            ],
            "editor/title/context": [
                {
                    "submenu": "sfmc-data.explorerContextMenu",
                    "when": "resourceFilename =~ /\\.dataExtension-(meta\\.json|doc\\.md)$/ || resourceFilename =~ /\\.mcdata\\./",
                    "group": "sfmc@1"
                }
            ],
            "editor/context": [
                {
                    "submenu": "sfmc-data.explorerContextMenu",
                    "when": "resourceFilename =~ /\\.dataExtension-(meta\\.json|doc\\.md)$/ || resourceFilename =~ /\\.mcdata\\./",
                    "group": "sfmc@1"
                }
            ],
            "sfmc-data.explorerContextMenu": [
                {
                    "command": "sfmc-data.contextExportDE",
                    "group": "1_export@1"
                },
                {
                    "command": "sfmc-data.contextExportFromBUs",
                    "group": "1_export@2"
                },
                {
                    "command": "sfmc-data.contextImportDE",
                    "group": "2_import@1"
                },
                {
                    "command": "sfmc-data.contextImportToBU",
                    "group": "2_import@2"
                }
            ]
        },
        "configuration": {
            "title": "SFMC Data Loader",
            "properties": {
                "sfmcData.mcdataSource": {
                    "type": "string",
                    "enum": [
                        "bundled",
                        "auto",
                        "custom"
                    ],
                    "enumDescriptions": [
                        "Use only the minified CLI shipped with this extension (`node …/out/mcdata.bundled.cjs`). Does not probe workspace `.bin` or `PATH`.",
                        "Resolve like before: workspace `node_modules/.bin/mcdata` when present, then `mcdata` on the process `PATH` (shell lookup), then the bundled CLI.",
                        "Use the executable path from `sfmcData.mcdataPath` (must be non-empty)."
                    ],
                    "enumItemLabels": [
                        "Bundled only",
                        "Auto (workspace → PATH → bundled)",
                        "Custom path"
                    ],
                    "default": "bundled",
                    "description": "How to resolve the `mcdata` executable when the extension runs export/import commands."
                },
                "sfmcData.mcdataPath": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "Path to the `mcdata` executable. **Only used when `sfmcData.mcdataSource` is `custom`.** Ignored for `bundled` and `auto` (you can clear stale values)."
                },
                "sfmcData.useGitFilenames": {
                    "type": "boolean",
                    "default": false,
                    "description": "Append --git to every mcdata invocation (stable *.mcdata.<ext> filenames without a timestamp)."
                },
                "sfmcData.promptClearBeforeImport": {
                    "type": "boolean",
                    "default": true,
                    "description": "After choosing import options, prompt whether to clear target DE rows before import (two-step confirmation)."
                },
                "sfmcData.promptImportMode": {
                    "type": "boolean",
                    "default": true,
                    "description": "When true, prompt for upsert vs insert before the optional clear-before-import step; when false, use import mode from settings only."
                },
                "sfmcData.importMode": {
                    "type": "string",
                    "enum": [
                        "upsert",
                        "insert"
                    ],
                    "enumDescriptions": [
                        "Update if primary key exists, else insert (async bulk API)",
                        "Insert new rows only (async bulk API)"
                    ],
                    "default": "upsert",
                    "description": "Default row write mode for imports when not prompting (async REST bulk endpoints only)."
                },
                "sfmcData.defaultFormat": {
                    "type": "string",
                    "enum": [
                        "csv",
                        "tsv",
                        "json"
                    ],
                    "default": "csv",
                    "description": "Default file format for exports. Import format is detected automatically from the file extension."
                },
                "sfmcData.backupBeforeImport": {
                    "type": "string",
                    "enum": [
                        "prompt",
                        "always",
                        "never"
                    ],
                    "enumItemLabels": [
                        "Always ask",
                        "Always backup",
                        "Never backup"
                    ],
                    "markdownEnumDescriptions": [
                        "Before each import, show a QuickPick asking whether to export a timestamped backup of the current target DE rows (passes `--backup-before-import` or `--no-backup-before-import` based on your answer).",
                        "Always export a timestamped backup of the target DE rows before import without asking (passes `--backup-before-import`).",
                        "Never export a backup before import (passes `--no-backup-before-import`)."
                    ],
                    "default": "prompt",
                    "description": "Whether to export a timestamped backup of each target Data Extension before import."
                },
                "sfmcData.createDebugLog": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "Append `--debug` when the extension runs the `mcdata` CLI (same flag as the standalone CLI). Writes API request/response traces under `./logs/data/` in the project — useful as a baseline for [support issues](https://github.com/JoernBerkefeld/vscode-sfmc-dataloader/issues). Does **not** apply to **Refresh DE cache** (that path uses the library in-process, not `mcdata`)."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run bundle:mcdata && npm run esbuild -- --minify",
        "bundle:mcdata": "node ./scripts/bundle-mcdata.mjs",
        "esbuild": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap --define:import.meta.url='\"\"'",
        "compile": "npm run bundle:mcdata && npm run esbuild && tsc -p tsconfig.test.json",
        "watch": "npm run esbuild -- --watch",
        "package": "npx @vscode/vsce package",
        "package:test": "npx @vscode/vsce package --pre-release --no-dependencies -o sfmc-data-BETA.vsix",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "prepare": "husky || true",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "node --test out/test/**/*.test.js"
    }
}
