{
    "name": "sfmc-data",
    "displayName": "SFMC Data Loader",
    "description": "Export and import Marketing Cloud Data Extension rows via the mcdata CLI (sfmc-dataloader).",
    "author": "JÃ¶rn Berkefeld",
    "license": "MIT",
    "version": "0.7.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/JoernBerkefeld/vscode-sfmc-data.git"
    },
    "bugs": {
        "url": "https://github.com/JoernBerkefeld/vscode-sfmc-data/issues"
    },
    "publisher": "joernberkefeld",
    "categories": [
        "Other"
    ],
    "keywords": [
        "sfmc",
        "salesforce",
        "marketing cloud",
        "data extension",
        "mcdev",
        "mcdata",
        "sfmc-dataloader",
        "csv",
        "tsv",
        "json",
        "exacttarget"
    ],
    "icon": "resources/images/sfmc-dataloader-256.png",
    "galleryBanner": {
        "color": "#032d60",
        "theme": "dark"
    },
    "engines": {
        "vscode": "^1.101.0"
    },
    "main": "./out/extension.js",
    "extensionPack": [
        "Accenture-oss.sfmc-devtools-vscode"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25",
        "@types/vscode": "^1.101.0",
        "@vscode/vsce": "^3.7.1",
        "esbuild": "^0.25.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^62.0.0",
        "eslint-plugin-prettier": "^5.5.0",
        "eslint-plugin-unicorn": "^64.0.0",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "sfmc-dataloader": "^2.0.2",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.57.2"
    },
    "contributes": {
        "commands": [
            {
                "command": "sfmc-data.exportDE",
                "title": "Export DE Data",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.exportDEMultiBU",
                "title": "Export DE Data (Multi-BU)",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.importDE",
                "title": "Import DE Data",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.importDECrossBU",
                "title": "Import DE Data (Cross-BU)",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.contextExportDE",
                "title": "Export Data",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.contextImportDE",
                "title": "Import Data",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.contextImportToBU",
                "title": "Import to BU...",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.contextExportFromBUs",
                "title": "Export from BUs...",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.showWhatsNew",
                "title": "Show What's New",
                "category": "SFMC Data"
            }
        ],
        "submenus": [
            {
                "id": "sfmc-data.explorerContextMenu",
                "label": "SFMC Data Loader"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "sfmc-data.exportDE",
                    "when": "workspaceFolderCount > 0"
                },
                {
                    "command": "sfmc-data.exportDEMultiBU",
                    "when": "workspaceFolderCount > 0"
                },
                {
                    "command": "sfmc-data.importDE",
                    "when": "workspaceFolderCount > 0"
                },
                {
                    "command": "sfmc-data.importDECrossBU",
                    "when": "workspaceFolderCount > 0"
                },
                {
                    "command": "sfmc-data.contextExportDE",
                    "when": "false"
                },
                {
                    "command": "sfmc-data.contextImportDE",
                    "when": "false"
                },
                {
                    "command": "sfmc-data.contextImportToBU",
                    "when": "false"
                },
                {
                    "command": "sfmc-data.contextExportFromBUs",
                    "when": "false"
                }
            ],
            "explorer/context": [
                {
                    "submenu": "sfmc-data.explorerContextMenu",
                    "when": "resourceFilename =~ /\\.dataExtension-(meta\\.json|doc\\.md)$/ || resourceFilename =~ /\\.mcdata\\./",
                    "group": "sfmc@1"
                }
            ],
            "sfmc-data.explorerContextMenu": [
                {
                    "command": "sfmc-data.contextExportDE",
                    "group": "1_export@1"
                },
                {
                    "command": "sfmc-data.contextExportFromBUs",
                    "group": "1_export@2"
                },
                {
                    "command": "sfmc-data.contextImportDE",
                    "group": "2_import@1"
                },
                {
                    "command": "sfmc-data.contextImportToBU",
                    "group": "2_import@2"
                }
            ]
        },
        "configuration": {
            "title": "SFMC Data Loader",
            "properties": {
                "sfmcData.mcdataSource": {
                    "type": "string",
                    "enum": [
                        "bundled",
                        "auto",
                        "custom"
                    ],
                    "enumDescriptions": [
                        "Use only the minified CLI shipped with this extension (`node â€¦/out/mcdata.bundled.cjs`). Does not probe workspace `.bin` or `PATH`.",
                        "Resolve like before: workspace `node_modules/.bin/mcdata` when present, then `mcdata` on the integrated terminal `PATH`, then the bundled CLI.",
                        "Use the executable path from `sfmcData.mcdataPath` (must be non-empty)."
                    ],
                    "enumItemLabels": [
                        "Bundled only",
                        "Auto (workspace â†’ PATH â†’ bundled)",
                        "Custom path"
                    ],
                    "default": "bundled",
                    "description": "How to resolve the `mcdata` CLI for commands run in the integrated terminal."
                },
                "sfmcData.mcdataPath": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "Path to the `mcdata` executable. **Only used when `sfmcData.mcdataSource` is `custom`.** Ignored for `bundled` and `auto` (you can clear stale values)."
                },
                "sfmcData.useGitFilenames": {
                    "type": "boolean",
                    "default": false,
                    "description": "Append --git to every mcdata invocation (stable *.mcdata.<ext> filenames without a timestamp)."
                },
                "sfmcData.promptClearBeforeImport": {
                    "type": "boolean",
                    "default": false,
                    "description": "After choosing import options, prompt whether to clear target DE rows before import (two-step confirmation)."
                },
                "sfmcData.promptImportMode": {
                    "type": "boolean",
                    "default": false,
                    "description": "When true, prompt for upsert vs insert before the optional clear-before-import step; when false, use import mode from settings only."
                },
                "sfmcData.importMode": {
                    "type": "string",
                    "enum": [
                        "upsert",
                        "insert"
                    ],
                    "enumDescriptions": [
                        "Update if primary key exists, else insert (async bulk API)",
                        "Insert new rows only (async bulk API)"
                    ],
                    "default": "upsert",
                    "description": "Default row write mode for imports when not prompting (async REST bulk endpoints only)."
                },
                "sfmcData.defaultMode": {
                    "type": "string",
                    "enum": [
                        "upsert",
                        "insert"
                    ],
                    "enumDescriptions": [
                        "Update if primary key exists, else insert (async bulk API)",
                        "Insert new rows only (async bulk API)"
                    ],
                    "default": "upsert",
                    "description": "Deprecated: use sfmcData.importMode. Kept for backward compatibility.",
                    "markdownDeprecationMessage": "Replaced by `#sfmcData.importMode#`. This setting is read only when `importMode` is unset at every scope.",
                    "deprecationMessage": "Replaced by sfmcData.importMode."
                },
                "sfmcData.defaultFormat": {
                    "type": "string",
                    "enum": [
                        "csv",
                        "tsv",
                        "json"
                    ],
                    "default": "csv",
                    "description": "Default file format for exports and imports."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run bundle:mcdata && npm run esbuild -- --minify",
        "bundle:mcdata": "node ./scripts/bundle-mcdata.mjs",
        "esbuild": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
        "compile": "npm run bundle:mcdata && npm run esbuild && tsc -p tsconfig.test.json",
        "watch": "npm run esbuild -- --watch",
        "package": "npx @vscode/vsce package",
        "package:test": "npx @vscode/vsce package --pre-release -o sfmc-data-BETA.vsix",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "node --test out/test/**/*.test.js"
    }
}
