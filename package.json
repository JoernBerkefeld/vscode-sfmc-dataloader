{
    "name": "sfmc-data",
    "displayName": "SFMC Data Loader",
    "description": "Export and import Marketing Cloud Data Extension rows via the mcdata CLI (sfmc-dataloader).",
    "author": "Jörn Berkefeld",
    "license": "MIT",
    "version": "0.1.1",
    "repository": {
        "type": "git",
        "url": "https://github.com/JoernBerkefeld/vscode-sfmc-data.git"
    },
    "bugs": {
        "url": "https://github.com/JoernBerkefeld/vscode-sfmc-data/issues"
    },
    "publisher": "joernberkefeld",
    "categories": [
        "Other"
    ],
    "keywords": [
        "sfmc",
        "salesforce",
        "marketing cloud",
        "data extension",
        "mcdev",
        "mcdata",
        "sfmc-dataloader",
        "csv",
        "tsv",
        "json",
        "exacttarget"
    ],
    "icon": "resources/images/sfmc-dataloader-256.png",
    "galleryBanner": {
        "color": "#032d60",
        "theme": "dark"
    },
    "engines": {
        "vscode": "^1.101.0"
    },
    "main": "./out/extension.js",
    "activationEvents": [
        "onStartupFinished"
    ],
    "peerDependencies": {
        "sfmc-dataloader": "*"
    },
    "contributes": {
        "commands": [
            {
                "command": "sfmc-data.exportDE",
                "title": "Export DE Data",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.exportDEMultiBU",
                "title": "Export DE Data (Multi-BU)",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.importDE",
                "title": "Import DE Data",
                "category": "SFMC Data"
            },
            {
                "command": "sfmc-data.importDECrossBU",
                "title": "Import DE Data (Cross-BU)",
                "category": "SFMC Data"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "sfmc-data.exportDE",
                    "when": "workspaceFolderCount > 0"
                },
                {
                    "command": "sfmc-data.exportDEMultiBU",
                    "when": "workspaceFolderCount > 0"
                },
                {
                    "command": "sfmc-data.importDE",
                    "when": "workspaceFolderCount > 0"
                },
                {
                    "command": "sfmc-data.importDECrossBU",
                    "when": "workspaceFolderCount > 0"
                }
            ]
        },
        "configuration": {
            "title": "SFMC Data Loader",
            "properties": {
                "sfmcData.mcdataPath": {
                    "type": "string",
                    "default": "",
                    "markdownDescription": "Optional path to the `mcdata` binary. Leave blank to use `mcdata` from `PATH` or `npx sfmc-dataloader`."
                },
                "sfmcData.importApi": {
                    "type": "string",
                    "enum": [
                        "async",
                        "sync"
                    ],
                    "enumDescriptions": [
                        "Use the asynchronous DE rows API (recommended for large files)",
                        "Use the synchronous DE rows API (immediate error feedback)"
                    ],
                    "default": "async",
                    "description": "REST API family used for imports."
                },
                "sfmcData.defaultMode": {
                    "type": "string",
                    "enum": [
                        "upsert",
                        "insert",
                        "update"
                    ],
                    "enumDescriptions": [
                        "Insert new rows, update existing rows (default)",
                        "Insert new rows only (sync API only)",
                        "Update existing rows only (sync API only)"
                    ],
                    "default": "upsert",
                    "description": "Default row write mode for imports."
                },
                "sfmcData.defaultFormat": {
                    "type": "string",
                    "enum": [
                        "csv",
                        "tsv",
                        "json"
                    ],
                    "default": "csv",
                    "description": "Default file format for exports and imports."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run esbuild -- --minify",
        "esbuild": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
        "compile": "npm run esbuild && tsc -p tsconfig.test.json",
        "watch": "npm run esbuild -- --watch",
        "package": "npx @vscode/vsce package --no-dependencies",
        "package:test": "npx @vscode/vsce package --no-dependencies --pre-release -o sfmc-data-BETA.vsix",
        "lint": "eslint src",
        "test": "node --test out/test/**/*.test.js"
    },
    "devDependencies": {
        "@types/node": "^22",
        "@types/vscode": "^1.101.0",
        "@vscode/vsce": "^3.7.1",
        "esbuild": "^0.25.0",
        "typescript": "^5.9.2"
    }
}
